# Telegram Bot token from @BotFather
BOT_TOKEN=123456:ABC-your-bot-token-here

# SQLite database path (Railway: use /data/bot.db with a volume)
DATABASE_PATH=bot.db

# Timezone for the daily 3 AM report
TIMEZONE=Asia/Kolkata

# Daily report hour (24h)
REPORT_HOUR=3
REPORT_MINUTE=0

# Logging level
LOG_LEVEL=INFO
